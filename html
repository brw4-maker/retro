<!DOCTYPE html>
<html lang="ku">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RETRO ERBIL</title>
  <style>
    body {
      background-color: #0b0c10;
      color: #fff;
      font-family: 'Press Start 2P', cursive;
      margin: 0;
      padding: 0;
    }
    header {
      background-color: #1f2833;
      text-align: center;
      padding: 20px;
      border-bottom: 3px solid #66fcf1;
    }
    header h1 {
      color: #ffcc00;
      text-shadow: 2px 2px #45a29e;
    }
    nav {
      background-color: #0b0c10;
      display: flex;
      justify-content: center;
      gap: 20px;
      padding: 10px;
    }
    nav a {
      color: #66fcf1;
      text-decoration: none;
      font-size: 14px;
    }
    nav a:hover {
      color: #ffcc00;
    }
    .banner {
      text-align: center;
      padding: 40px;
      background: linear-gradient(90deg, #1f2833, #0b0c10);
    }
    .banner h2 {
      color: #ffcc00;
    }
    .products {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      padding: 40px;
    }
    .product {
      background-color: #1f2833;
      border: 2px solid #45a29e;
      padding: 20px;
      text-align: center;
      border-radius: 8px;
    }
    .product img {
      width: 100%;
      height: auto;
    }
    .product button {
      background-color: #66fcf1;
      border: none;
      padding: 10px;
      cursor: pointer;
      font-family: inherit;
    }
    .product button:hover {
      background-color: #ffcc00;
    }
    footer {
      background-color: #1f2833;
      text-align: center;
      padding: 20px;
      font-size: 12px;
      border-top: 3px solid #66fcf1;
    }
  </style>
</head>
<body>
  <header>
    <h1>RETRO ERBIL</h1>
  </header>
  <nav>
    <a href="#">Games</a>
    <a href="#">Consoles</a>
    <a href="#">Merchandise</a>
    <a href="#">About Us</a>
  </nav>
  <section class="banner">
    <h2>Welcome to RETRO ERBIL</h2>
    <p>Your Ultimate Retro Gaming Store!</p>
    <button>SHOP NOW</button>
  </section>
  <section class="products">
    <div class="product">
      <img src="super-mario.jpg" alt="Super Mario Bros">
      <h3>Super Mario Bros</h3>
      <p>$25</p>
      <button>Add to Cart</button>
    </div>
    <div class="product">
      <img src="sega-mega-drive.jpg" alt="Sega Mega Drive">
      <h3>Sega Mega Drive</h3>
      <p>$90</p>
      <button>Add to Cart</button>
    </div>
    <div class="product">
      <img src="gameboy.jpg" alt="Game Boy">
      <h3>Game Boy</h3>
      <p>$60</p>
      <button>Add to Cart</button>
    </div>
  </section>
  <footer>
    <p>© 2026 Retro Erbil - Erbil, Iraq | Powered by RetroTech</p>
  </footer>
</body>
</html>
